{
  "name": "Webhook Meta Lead Ads",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "meta-leads",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook /meta-leads",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "meta-leads"
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst entries = body.entry || [];\nconst out = [];\nfor (const e of entries) {\n  for (const ch of (e.changes || [])) {\n    if (ch.field === 'leadgen' && ch.value?.leadgen_id) {\n      out.push({ json: { leadgen_id: ch.value.leadgen_id, page_id: ch.value.page_id, ad_id: ch.value.ad_id, campaign_id: ch.value.campaign_id } });\n    }\n  }\n}\nreturn out.length ? out : [{ json: { skip: true } }];"
      },
      "id": "extractLeads",
      "name": "Extrair leadgen_ids",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            { "id": "1", "leftValue": "={{$json.skip}}", "rightValue": "true", "operator": { "type": "string", "operation": "notEquals" } }
          ],
          "combinator": "and"
        }
      },
      "id": "filterValid",
      "name": "Filtrar validos",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "url": "=https://graph.facebook.com/v21.0/{{$json.leadgen_id}}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "access_token", "value": "={{$env.META_ACCESS_TOKEN}}" }
          ]
        },
        "options": {}
      },
      "id": "fetchLead",
      "name": "Meta GET /leadgen_id",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "const out = [];\nfor (const it of $input.all()) {\n  const lead = it.json;\n  const fields = {};\n  for (const f of (lead.field_data || [])) fields[f.name] = (f.values && f.values[0]) || '';\n  const utm = (lead.ad_name || lead.campaign_name || '').toUpperCase();\n  let tipo = 'NAO_CLASSIFICADO';\n  if (utm.includes('UBER') || utm.includes('99') || utm.includes('MOTORISTA') || utm.includes('MOBILIDADE')) tipo = 'APP_MOBILIDADE';\n  else if (utm.includes('SERVIDOR') || utm.includes('PUB')) tipo = 'SERVIDOR_PUBLICO';\n  out.push({ json: {\n    wts_session_id: 'meta-' + lead.id,\n    nome: fields.full_name || fields.nome || fields.name || '',\n    telefone: fields.phone_number || fields.telefone || '',\n    status: 'Pendente',\n    utm_source: 'FACEBOOK',\n    utm_medium: 'LEAD_AD',\n    utm_campaign: lead.campaign_id || '',\n    utm_content: lead.ad_name || '',\n    primeira_mensagem: '',\n    data_criacao: lead.created_time\n  } });\n}\nreturn out;"
      },
      "id": "mapLead",
      "name": "Mapear lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "jsCode": "const arr = $input.all().map(it => it.json);\nreturn [{ json: { rows: arr } }];"
      },
      "id": "agruparLead",
      "name": "Agrupar lead",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://supabase.zapconnecta.com/rest/v1/leads",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MTkwMDAwMDAwMH0.kq70f17QKC1e1kh2nU5emk6YqNbUiJF2Odojbwo3ja0" },
            { "name": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MTkwMDAwMDAwMH0.kq70f17QKC1e1kh2nU5emk6YqNbUiJF2Odojbwo3ja0" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "resolution=merge-duplicates,return=minimal" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "on_conflict", "value": "wts_session_id" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json.rows) }}",
        "options": {}
      },
      "id": "upsertLead",
      "name": "Upsert lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 300]
    }
  ],
  "connections": {
    "Webhook /meta-leads": { "main": [[{ "node": "Extrair leadgen_ids", "type": "main", "index": 0 }]] },
    "Extrair leadgen_ids": { "main": [[{ "node": "Filtrar validos", "type": "main", "index": 0 }]] },
    "Filtrar validos": { "main": [[{ "node": "Meta GET /leadgen_id", "type": "main", "index": 0 }]] },
    "Meta GET /leadgen_id": { "main": [[{ "node": "Mapear lead", "type": "main", "index": 0 }]] },
    "Mapear lead": { "main": [[{ "node": "Agrupar lead", "type": "main", "index": 0 }]] },
    "Agrupar lead": { "main": [[{ "node": "Upsert lead", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": ["funil", "meta", "webhook"]
}
